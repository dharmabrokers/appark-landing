# ── Lead delivery — configure AT LEAST ONE channel, ideally both ──
# 1) n8n webhooks (optional)
N8N_EARLY_ACCESS_WEBHOOK_URL=
N8N_SPONSOR_WEBHOOK_URL=

# 2) Email fallback via SMTP (recommended — a lead NEVER gets lost).
#    Hostinger example: host smtp.hostinger.com, port 465 (SSL).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=hola@appark.es
SMTP_PASS=
# Inbox that receives every lead (defaults to SMTP_USER if empty).
LEADS_TO=hola@appark.es

# 3) Supabase — escribe los leads de sponsor directamente en la tabla
#    public.sponsor_leads para que aparezcan en el CRM (pipeline comercial).
#    Usa la anon key pública (la misma que el CRM y la app); la política RLS
#    "Allow public insert on sponsor_leads" (migración 0010) permite el INSERT.
NEXT_PUBLIC_SUPABASE_URL=https://vsxldnwhwaanuvjwnwhl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Anti-spam (optional; fails open if unset) ──
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Analytics ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-G3MV9DZD72
